<Window x:Class="DirectoryDash.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="Settings" Height="500" Width="600"
        Background="#FF1E1E1E"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Source Directories"
                   Foreground="White"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBox x:Name="FolderPathTextBox"
                         Width="400"
                         Height="35"
                         material:HintAssist.Hint="Select folder..."
                         TextWrapping="Wrap"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0"/>
                <Button Content="Browse" Width="80" Height="35"
                        Command="{Binding BrowseCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"/>
            </StackPanel>

            <Border Grid.Row="1" Background="#2D2D2D" CornerRadius="5" Padding="5" BorderBrush="#444" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="SavedDirectoriesList" ItemsSource="{Binding SavedPaths}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2">
                                    <TextBlock Text="{Binding}" Foreground="White" VerticalAlignment="Center" />
                                    <Button Content="Remove"
                                            Command="{Binding DataContext.RemovePathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            DockPanel.Dock="Right"
                                            Width="70"
                                            Height="25"
                                            Margin="5,0,0,0"
                                            Style="{StaticResource MaterialDesignFlatButton}"/>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0"
                    Style="{StaticResource MaterialDesignFlatButton}"/>
            <Button Content="Save" Width="100"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
        </StackPanel>
    </Grid>
</Window>