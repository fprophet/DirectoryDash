<Window x:Class="DirectoryDash.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:DirectoryDash"
        xmlns:converters="clr-namespace:DirectoryDash.Converters"
        xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:DirectoryDash.ViewModels"
        mc:Ignorable="d"
        Background="Transparent"
        WindowState="Maximized"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/DataTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="ContainerCanvasStyle" TargetType="ContentControl">
                <Setter Property="Canvas.Left" Value="{Binding ContainerData.XCoord}" />
                <Setter Property="Canvas.Top" Value="{Binding ContainerData.YCoord}" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Canvas HorizontalAlignment="Stretch"
                Visibility="{Binding IsListVisible, Converter={StaticResource BoolToVis}}">

            <ItemsControl ItemsSource="{Binding ContainersStore.AllContainers}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding ContainerData.XCoord}" />
                        <Setter Property="Canvas.Top" Value="{Binding ContainerData.YCoord}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ContainerViewModel}">
                        <ContentControl Content="{Binding}"
                            Canvas.Left="{Binding ContainerData.XCoord, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Canvas.Top="{Binding ContainerData.YCoord, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="Loaded">
                                    <i:InvokeCommandAction Command="{Binding OnLoadedCommand}" />
                                </i:EventTrigger>
                                
                                <i:EventTrigger EventName="MouseLeave">
                                    <i:InvokeCommandAction Command="{Binding DataContext.OnMouseLeaveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                </i:EventTrigger>
                                <i:EventTrigger EventName="MouseEnter">
                                    <i:InvokeCommandAction Command="{Binding DataContext.OnMouseEnterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </ContentControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Canvas>
    </Grid>
</Window>
